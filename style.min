:root{--color-primario:#027cfd;--color-hover:#fd0202;--color-fondo:#f0f0f0;--color-header:#333;--color-texto:#333;--color-blanco:#ffffff;--color-borde:#ddd;--color-boton-secundario:#0056b3;--color-acento:#007bff;--fuente-base:sans-serif;--tamano-base:1rem;--tamano-h1:1.5rem;--tamano-h2:1.25rem;--tamano-footer:0.9rem;--radio-borde:5px;--radio-borde-lg:8px;--radio-borde-xl:15px;--sombra-hover:0 10px 20px rgba(0,0,0,0.15);}*{margin:0;padding:0;box-sizing:border-box;}body{font-family:var(--fuente-base);background-color:var(--color-fondo);color:var(--color-texto);line-height:1.6;font-size:var(--tamano-base);}img{max-width:100%;height:auto;display:block;}header{background-color:var(--color-header);color:var(--color-blanco);padding:1.25rem 3.125rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;}header h1{font-size:var(--tamano-h1);}nav ul{display:flex;list-style:none;gap:0.9375rem;flex-wrap:wrap;}nav a,.lista-proyectos a{display:inline-block;color:var(--color-blanco);text-decoration:none;background-color:var(--color-primario);padding:0.625rem 1.25rem;border-radius:var(--radio-borde);transition:background-color 0.3s,transform 0.3s;font-weight:bold;text-align:center;}nav a:hover,.lista-proyectos a:hover{background-color:var(--color-hover);transform:scale(1.05);}main{max-width:50rem;margin:1.25rem auto;padding:0.625rem;}section{background:var(--color-blanco);margin-bottom:1.25rem;padding:1.25rem;border-radius:var(--radio-borde-lg);}h2{margin-bottom:0.9375rem;color:var(--color-acento);font-size:var(--tamano-h2);}.lista-proyectos{display:grid;grid-template-columns:repeat(3,1fr);gap:0.9375rem;padding:0.625rem 0;}.lista-proyectos.oculto{display:none;}.bienvenida-banner{background-color:var(--color-primario);color:var(--color-blanco);padding:0.75rem 1.25rem;border-radius:var(--radio-borde);display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;font-size:1rem;}.bienvenida-banner.oculto{display:none;}.btn-cerrar{background:transparent;color:var(--color-blanco);border:none;font-size:1.1rem;cursor:pointer;padding:0 0.5rem;border-radius:var(--radio-borde);transition:background-color 0.2s;}.btn-cerrar:hover{background-color:rgba(255,255,255,0.2);}.btn-secundario{background-color:var(--color-boton-secundario);color:var(--color-blanco);padding:0.625rem 1.25rem;border:none;border-radius:var(--radio-borde);cursor:pointer;font-size:0.9rem;margin-top:0.75rem;transition:background-color 0.3s,transform 0.2s;}.btn-secundario:hover{background-color:var(--color-hover);transform:scale(1.03);}.formulario-grup{margin-bottom:0.9375rem;}input,textarea{width:100%;padding:0.625rem;border:1px solid #ccc;border-radius:4px;margin-top:0.3125rem;font-size:var(--tamano-base);}button[type="submit"]{background-color:var(--color-boton-secundario);color:var(--color-blanco);padding:0.625rem 1.25rem;border:none;border-radius:var(--radio-borde);cursor:pointer;font-size:var(--tamano-base);transition:background-color 0.3s;}button[type="submit"]:hover{background-color:var(--color-hover);}footer{background-color:var(--color-header);color:var(--color-blanco);text-align:center;padding:1.25rem;font-size:var(--tamano-footer);}#galeria{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;background:transparent;max-width:62.5rem;margin:0 auto;}#galeria article{background:var(--color-blanco);border:2px solid var(--color-borde);border-radius:var(--radio-borde-xl);padding:0.9375rem;transition:border-color 0.3s,transform 0.3s,box-shadow 0.3s;text-align:center;}#galeria article img{width:100%;height:18.75rem;object-fit:cover;border-radius:0.625rem;margin-bottom:0.9375rem;}#galeria article:hover{border-color:var(--color-hover);transform:translateY(-0.625rem);box-shadow:var(--sombra-hover);}@media (max-width:1024px) and (min-width:601px){.lista-proyectos{grid-template-columns:repeat(2,1fr);}#galeria{grid-template-columns:repeat(3,1fr);}}@media (max-width:600px){header{flex-direction:column;align-items:flex-start;padding:1rem 1.25rem;}nav ul{flex-direction:column;gap:0.5rem;width:100%;}nav a{width:100%;text-align:center;}main{padding:0.625rem;}.lista-proyectos{grid-template-columns:1fr;}#galeria{grid-template-columns:repeat(2,1fr);}h2{font-size:1.1rem;}body{font-size:0.9375rem;}}